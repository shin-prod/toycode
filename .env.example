# ===================================================
# AI ディレクトリ設定
# モジュール・ツールの配置先（書き込み制限の基準にもなる）
# ===================================================
AI_DIR=.myagent

# ===================================================
# LLM プロバイダー選択
# 使用するプロバイダー: openrouter または azure
# ===================================================
LLM_PROVIDER=openrouter

# ===================================================
# OpenRouter 設定
# ===================================================
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# （任意）あなたのサイト名・アプリ名（OpenRouter ダッシュボード表示用）
OPENROUTER_SITE_URL=https://your-site.com
OPENROUTER_APP_NAME=MyCLITool

# ===================================================
# Azure OpenAI 設定
# ===================================================
AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# ===================================================
# エージェント動作設定
# ===================================================
# LLM への最大入力トークン数（コンテキストウィンドウ上限）
MAX_CONTEXT_TOKENS=128000
# 1 回の応答で生成する最大トークン数
MAX_OUTPUT_TOKENS=8192
# temperature (0.0 ～ 2.0)
TEMPERATURE=0.7
# ストリーミング出力の有効/無効
STREAM=true
# エージェントループの最大回数（ツール呼び出し含む）
MAX_AGENT_LOOPS=20

# ===================================================
# ツール設定
# ===================================================
# シェルコマンド実行を許可するか (true/false)
ALLOW_SHELL_EXEC=true
# Python コード実行を許可するか (true/false)
ALLOW_CODE_EXEC=true
# 作業ディレクトリ（省略時は AI_DIR と同じ）
# WORKSPACE_DIR=.myagent

# ===================================================
# ログ設定
# ===================================================
LOG_LEVEL=INFO
LOG_FILE=agent.log
